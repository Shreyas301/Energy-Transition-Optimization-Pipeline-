# ==========================================
# ENERGY PIPELINE - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in your own values.
# NEVER commit the actual .env file to Git.

# --- PostgreSQL ---
POSTGRES_USER=energy_admin
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=energy_db

# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=change_this_n8n_password

# --- API ---
API_BASE_URL=https://api.energy-charts.info/public_power
DEFAULT_COUNTRY=de
